{
	"name": "Ubuntu",
	"image": "mcr.microsoft.com/devcontainers/base:resolute",
	"features": {
		"ghcr.io/stu-bell/devcontainer-features/homebrew:1": {
			"brewPackage": "hugo"
		},
		"ghcr.io/devcontainers/features/git-lfs:1": {},
